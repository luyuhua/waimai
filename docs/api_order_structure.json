{
  "api": "/gw/api/unified/r/order/list/page/unprocessed",
  "method": "POST",
  "requestBody": {
    "tag": "all | pending_accept | pending_cook | etc.",
    "pageParam": {
      "pageSize": 10,
      "pageNum": 1,
      "sort": 0,
      "nextLabel": "",
      "lastLabel": ""
    },
    "extParam": {
      "phfRollback": 0,
      "searchMealTag": ""
    }
  },
  "responseStructure": {
    "code": "0=success",
    "data.orderIndex": "Array of {wmOrderViewId, version}",
    "data.orderList": "Array of order objects",
    "data.pageInfo": "{mode, totalCount, pageCount, nextLabel, lastLabel}",
    "data.extData": "{processCount, cancelCount}"
  },
  "orderFields_from_commonInfo": {
    "wm_order_id_view": "Order display ID",
    "wm_poi_order_dayseq": "Order sequence number (#9 etc)",
    "order_time": "Unix timestamp of order time",
    "order_time_fmt": "Formatted order time like 06-09 17:06",
    "estimateArrivalTime": "Unix timestamp of estimated arrival time",
    "confirmTime": "Unix timestamp of confirmation time",
    "orderType": "0=normal, 2=pre-order(? TBD)",
    "isPreOrder": "from basicVo, boolean",
    "preOrderShowInTabTime": "Non-zero for pre-orders shown in tab",
    "refundType": "-1=none"
  },
  "orderFields_from_basicVo": {
    "status": {
      "4": "已接单/已出餐 (combined state, use statusDesc for detail)",
      "8": "已完成/已送达",
      "NOTE": "Status in API differs from DOM text! Use statusDesc for display text."
    },
    "isPreOrder": "Boolean - true for pre-orders",
    "orderTime": "Unix ms timestamp",
    "estimateArrivalTime": "Unix ms timestamp",
    "confirmTime": "Unix ms timestamp",
    "shippingService": "1020=美团配送(?)"
  },
  "keyInsights": [
    "1. API uses tag parameter to filter: all, pending_cook, etc.",
    "2. API supports pagination with pageSize/pageNum",
    "3. status=4 in API maps to both 待出餐 and 已出餐 in DOM - need statusDesc",
    "4. suggestCookTimeVo was empty for completed orders - likely only present for pending_cook",
    "5. isPreOrder in basicVo clearly identifies pre-orders",
    "6. All timestamps are unix milliseconds"
  ]
}